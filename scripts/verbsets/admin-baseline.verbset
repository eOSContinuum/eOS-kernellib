# Built-in admin-console verbs -- a small read-only regression baseline
# proving the console itself responds before extension verbsets run.
#
#   scripts/drive-verbs.py scripts/verbsets/admin-baseline.verbset

cmd: status
expect: Server:\s+DGD
expect: Uptime:

cmd: users
expect: Logged on:.*admin

cmd: code 1 + 1
expect: \$\d+ = 2
